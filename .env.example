LLM_BASE_URL=http://localhost:8001/v1
LLM_API_KEY=not-needed
LLM_MODEL=./llm_model/qwen3-4b-4bit-mlx
# LLM_MAX_CONTEXT_TOKENS=32768

# SQLite database path (relative to project root)
# DATABASE_PATH=data/app.db

# Backend health check interval in seconds (LLM, MCP, agents)
# HEALTH_CHECK_INTERVAL_SECONDS=30

# Backend service
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8080

# Frontend service
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=9001

# Frontend -> Backend API (Vite dev proxy / nginx container)
BACKEND_API_HOST=localhost
BACKEND_API_PORT=8080

# MCP server endpoints (override config/mcp_servers.yaml)
# Server key는 mcp_servers.yaml의 키와 동일 (대문자 + 언더스코어)
#
# Agent -> MCP mapping:
#   dprv6-k8s, pcicd-k8s, dprv-k8s, dprsv-k8s, dprmn-k8s, dprrt-k8s, dpvs-k8s, dtest-k8s
#     -> kubernetes, kubectl_ai
#   kubevirt -> kubernetes
#   vcenter  -> vcenter
#   ansible  -> ansible
#
# MCP_KUBERNETES_URL=http://k8smcp.ora01000.pe.kr:32716/mcp
# MCP_KUBERNETES_ENABLED=true
# MCP_KUBECTL_AI_URL=http://kubectl-ai.ora01000.pe.kr:32716/mcp
# MCP_KUBECTL_AI_ENABLED=true
# MCP_VCENTER_URL=http://localhost:9090/mcp
# MCP_VCENTER_ENABLED=false
# MCP_ANSIBLE_URL=http://localhost:9091/mcp
# MCP_ANSIBLE_ENABLED=false

# Job notification - Email (SMTP)
# EMAIL_ENABLED=true
# EMAIL_SMTP_HOST=smtp.example.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USERNAME=notify@example.com
# EMAIL_SMTP_PASSWORD=secret
# EMAIL_FROM_ADDRESS=notify@example.com
# EMAIL_USE_TLS=true
# EMAIL_USE_SSL=false
# EMAIL_TIMEOUT_SECONDS=30

# Job notification - MS Teams
# TEAMS_ENABLED=true
# TEAMS_MODE=webhook
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...
#
# Graph API mode (TEAMS_MODE=graph)
# TEAMS_TENANT_ID=
# TEAMS_CLIENT_ID=
# TEAMS_CLIENT_SECRET=
# TEAMS_TEAM_ID=
# TEAMS_CHANNEL_ID=
# TEAMS_TIMEOUT_SECONDS=30

# System Inventory (ChromaDB)
# CHROMA_DATA_PATH=data/chroma
# INVENTORY_CSV_PATH=data/inventory/inventory.csv

# Whatap event webhook (optional secret for X-Whatap-Secret header)
# WHATAP_WEBHOOK_SECRET=

# Integrated chat user communication logs
# USER_COMM_LOG=data/user_comm_logs
# USER_COMM_RETENTION=30

# Job requester daemon (disabled; use Settings > 테스트 작업 발송 instead)
# JOB_REQUESTER_ENABLED=false
# JOB_REQUESTER_INTERVAL_MINUTES=60
# JOB_REQUESTER_INITIAL_DELAY_SECONDS=60

# Job requester daemon (disabled; use Settings > 테스트 작업 발송 instead)
# JOB_REQUESTER_ENABLED=false
# JOB_REQUESTER_INTERVAL_MINUTES=60
# JOB_REQUESTER_INITIAL_DELAY_SECONDS=60

# Kubernetes inventory collector (openshift DynamicClient, sync)
# Startup: collect all once. Then daily from 00:10 with 5-minute stagger by agent order.
# K8S_COLLECTOR_ENABLED=true
# K8S_COLLECTOR_COLLECT_ON_STARTUP=true
# K8S_COLLECTOR_SCHEDULE_HOUR=0
# K8S_COLLECTOR_SCHEDULE_MINUTE=10
# K8S_COLLECTOR_STAGGER_MINUTES=5
# K8S_COLLECTOR_KUBECONFIG=
# K8S_COLLECTOR_FALLBACK_CURRENT_CONTEXT=true

# Auth provider: db (default, local users table) | madang (OAUTH_PROXY)
# AUTH_PROVIDER_TYPE=db
# AUTH_PROVIDER_TYPE=madang
# OAUTH_PROXY=http://oauth.lguplus-securities.svc.cluster.local:8080
